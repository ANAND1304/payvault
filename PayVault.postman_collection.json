{
  "info": {
    "name": "PayVault API",
    "description": "Complete PayVault payment gateway API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:8080" },
    { "key": "TOKEN", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@demo.com\",\n  \"password\": \"demo1234\",\n  \"fullName\": \"John Doe\",\n  \"businessName\": \"Acme Payments\",\n  \"phone\": \"+919876543210\",\n  \"role\": \"MERCHANT\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('TOKEN', res.data.token);",
                  "  console.log('Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"merchant@demo.com\",\n  \"password\": \"demo1234\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{TOKEN}}" }
            ],
            "url": "{{BASE_URL}}/api/v1/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1499.00,\n  \"currency\": \"INR\",\n  \"description\": \"Premium Plan Subscription\",\n  \"customerEmail\": \"customer@email.com\",\n  \"customerName\": \"Jane Smith\",\n  \"customerPhone\": \"+919876543210\"\n}"
            }
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/v1/orders?page=0&size=10"
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/v1/orders/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get Order by Link Token",
          "request": {
            "method": "GET",
            "url": "{{BASE_URL}}/api/v1/pay/link/YOUR_TOKEN_HERE"
          }
        },
        {
          "name": "Process Payment (Card - Success)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/pay/process",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderReference\": \"ORD-XXXXXX-XXXXXXXX\",\n  \"paymentMethod\": \"CARD\",\n  \"cardNumber\": \"4111111111111111\",\n  \"cardHolderName\": \"JOHN DOE\",\n  \"expiryMonth\": \"08\",\n  \"expiryYear\": \"27\",\n  \"cvv\": \"123\"\n}"
            }
          }
        },
        {
          "name": "Process Payment (Card - Force Fail)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/pay/process",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderReference\": \"ORD-XXXXXX-XXXXXXXX\",\n  \"paymentMethod\": \"CARD\",\n  \"cardNumber\": \"4111111111110000\",\n  \"cardHolderName\": \"JOHN DOE\",\n  \"expiryMonth\": \"08\",\n  \"expiryYear\": \"27\",\n  \"cvv\": \"123\"\n}"
            }
          }
        },
        {
          "name": "Process Payment (UPI)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/pay/process",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderReference\": \"ORD-XXXXXX-XXXXXXXX\",\n  \"paymentMethod\": \"UPI\",\n  \"upiId\": \"john@gpay\"\n}"
            }
          }
        },
        {
          "name": "Retry Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BASE_URL}}/api/v1/pay/retry/TRANSACTION_UUID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderReference\": \"ORD-XXXXXX-XXXXXXXX\",\n  \"paymentMethod\": \"CARD\",\n  \"cardNumber\": \"4111111111111111\",\n  \"cardHolderName\": \"JOHN DOE\",\n  \"cvv\": \"123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/v1/transactions?page=0&size=10"
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "url": "{{BASE_URL}}/api/v1/transactions/TRANSACTION_UUID_HERE"
          }
        }
      ]
    }
  ]
}
